@model GamesRental.Web.ViewModels.Game.GameCatalogPageViewModel

@{
    ViewData["Title"] = "Game Catalog";
}

<h2 class="mb-4">Available Games</h2>

<form method="get" asp-controller="Game" asp-action="Catalog" class="row g-2 mb-4">
    <div class="col-md-6">
        <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search by title, genre or platform" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
    <div class="col-auto">
        <a asp-controller="Game" asp-action="Catalog" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (!Model.Games.Any())
{
    <div class="alert alert-info">No games are currently available for rent.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var game in Model.Games)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="game-cover-frame">
                        <img src="@game.ImageUrl" alt="@game.Title" class="card-img-top game-cover-image" />
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@game.Title</h5>
                        <p class="card-text mb-1">
                            <strong>Genre:</strong> @game.Genre<br />
                            <strong>Platform:</strong> @game.Platform<br />
                            <strong>Available Copies:</strong> @game.AvailableCopies
                        </p>
                        <a asp-controller="Game" asp-action="Details" asp-route-id="@game.Id" class="btn btn-primary mt-auto">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">
        <div class="text-muted">
            Page @Model.CurrentPage of @Model.TotalPages
            <span class="ms-2">(@Model.TotalGames games)</span>
        </div>

        <div class="d-flex gap-2">
            @if (Model.HasPreviousPage)
            {
                <a asp-controller="Game" asp-action="Catalog" asp-route-searchTerm="@Model.SearchTerm" asp-route-currentPage="@(Model.CurrentPage - 1)" class="btn btn-outline-primary">Previous</a>
            }

            @if (Model.HasNextPage)
            {
                <a asp-controller="Game" asp-action="Catalog" asp-route-searchTerm="@Model.SearchTerm" asp-route-currentPage="@(Model.CurrentPage + 1)" class="btn btn-outline-primary">Next</a>
            }
        </div>
    </div>
}
